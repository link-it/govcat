{
  "name": "apicat-workspace",
  "version": "2.3.3",
  "scripts": {
    "ng": "ng",
    "start-apicat": "ng serve apicat-app --port 6200",
    "start-apicat-proxy": "node ./builder.version.mjs --project=apicat-app --develop=true && ng serve apicat-app --proxy-config proxy.config.json --port 6200",
    "start-apicat-baseref": "ng serve apicat-app --configuration=development-baseref",
    "production-apicat": "node ./builder.version.mjs --project=apicat-app && npm run distribution-apicat",
    "distribution-apicat": "npm run build-apicat",
    "build-apicat": "ng build apicat-app --configuration production --aot=true --output-hashing none --base-href /apicat-app/",
    "clean-apicat": "rm -r ./dist/apicat-app/assets/scss && rm -r ./dist/apicat-app/assets/*.js",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test apicat-app --no-watch --coverage",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "e2e:headed": "npx playwright test --headed",
    "e2e:report": "npx playwright show-report",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "audit:prod": "npm audit --omit=dev",
    "audit:better": "better-npm-audit audit",
    "audit:better:prod": "npm audit --omit=dev --json | better-npm-audit audit",
    "postinstall": "node scripts/patch-ts-md5.mjs",
    "audit:ci": "audit-ci --config audit-ci.json",
    "license:add": "licenseheaders -t license-header.txt -cy -d ./projects -E .ts .js .html .css .scss && licenseheaders -t license-header.txt -cy -f *.js *.mjs",
    "license:check": "FILES=$( { find ./projects -type f \\( -name '*.ts' -o -name '*.js' -o -name '*.mjs' -o -name '*.html' -o -name '*.css' -o -name '*.scss' \\); find . -maxdepth 1 -type f \\( -name '*.ts' -o -name '*.js' -o -name '*.mjs' \\); } | xargs grep -L 'GovCat - GovWay API Catalogue' 2>/dev/null); if [ -n \"$FILES\" ]; then echo \"Files missing license header:\"; echo \"$FILES\"; exit 1; fi",
    "license:update-year": "{ find ./projects -type f \\( -name '*.ts' -o -name '*.js' -o -name '*.mjs' -o -name '*.html' -o -name '*.css' -o -name '*.scss' \\); find . -maxdepth 1 -type f \\( -name '*.ts' -o -name '*.js' -o -name '*.mjs' \\); } | xargs sed -i 's/2021-2026/2021-2027/g'"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.6",
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@fortawesome/angular-fontawesome": "^4.0.0",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@material/icon-button": "^14.0.0",
    "@ng-select/ng-select": "^21.4.0",
    "@ngx-translate/core": "^16.0.4",
    "@ngx-translate/http-loader": "^16.0.1",
    "@swimlane/ngx-charts": "^21.1.3",
    "angular-oauth2-oidc": "^20.0.2",
    "bootstrap": "^5.3.5",
    "bootstrap-icons": "^1.11.3",
    "css-vars-ponyfill": "^2.4.7",
    "d3": "^7.8.5",
    "d3-array": "^3.2.4",
    "d3-brush": "^3.0.0",
    "d3-color": "^3.1.0",
    "d3-force": "^3.0.0",
    "d3-format": "^3.1.0",
    "d3-hierarchy": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-time-format": "^4.1.0",
    "fast-json-patch": "^3.1.1",
    "file-saver": "^2.0.5",
    "html-to-image": "^1.11.13",
    "jquery": "^3.7.1",
    "jsrsasign": "^11.1.1",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.18.1",
    "marked": "^17.0.3",
    "masonry-layout": "^4.2.2",
    "material-icons": "^1.13.14",
    "moment": "^2.30.1",
    "ng2-currency-mask": "^13.0.3",
    "ngx-bootstrap": "^21.0.1",
    "ngx-gravatar": "^13.0.0",
    "ngx-infinite-scroll": "^21.0.0",
    "ngx-markdown": "^21.1.0",
    "ngx-masonry": "^14.0.1",
    "ngx-toastr": "^20.0.5",
    "placeholder-loading": "^0.7.0",
    "rxjs": "^7.8.2",
    "swagger-ui-dist": "^5.32.1",
    "tslib": "^2.3.0",
    "vite": "^6.4.2",
    "xml-viewer-component": "^0.4.2",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.6",
    "@playwright/test": "^1.58.2",
    "@types/d3-array": "^3.0.3",
    "@types/d3-ease": "^3.0.0",
    "@types/d3-interpolate": "^3.0.1",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.7",
    "@types/d3-transition": "^3.0.9",
    "@types/jquery": "^3.5.32",
    "@types/jsrsasign": "^10.5.15",
    "@types/lodash": "^4.17.16",
    "@types/node": "^22.13.10",
    "@types/swagger-ui-dist": "^3.30.1",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "audit-ci": "^7.1.0",
    "better-npm-audit": "^3.11.0",
    "commander": "^13.1.0",
    "jsdom": "^28.1.0",
    "replace-in-file": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "autoprefixer": "10.4.5",
    "memfs": "4.17.0",
    "dompurify": "3.3.3",
    "picomatch": "4.0.4",
    "lodash-es": "4.18.1",
    "@angular/build": {
      "vite": "7.3.2"
    },
    "@swimlane/ngx-charts": {
      "@angular/animations": "$@angular/animations",
      "@angular/cdk": "$@angular/cdk",
      "@angular/core": "$@angular/core",
      "@angular/forms": "$@angular/forms",
      "@angular/common": "$@angular/common",
      "@angular/platform-browser": "$@angular/platform-browser",
      "@angular/platform-browser-dynamic": "$@angular/platform-browser-dynamic"
    }
  }
}
