{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"cli": {
		"analytics": false
	},
	"version": 1,
	"newProjectRoot": "projects",
	"projects": {
		"apicat-app": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"style": "scss"
				},
				"@schematics/angular:application": {
					"strict": true
				}
			},
			"root": "projects/apicat-app",
			"sourceRoot": "projects/apicat-app/src",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "@angular/build:application",
					"options": {
						"outputPath": {
							"base": "dist/apicat-app",
							"browser": ""
						},
						"index": "projects/apicat-app/src/index.html",
						"browser": "projects/apicat-app/src/main.ts",
						"polyfills": [
							"zone.js"
						],
						"tsConfig": "projects/apicat-app/tsconfig.app.json",
						"allowedCommonJsDependencies": [
							"moment",
							"lodash",
							"ts-md5/dist/md5",
							"clone-deep",
							"rfdc",
							"ev-emitter/ev-emitter",
							"jsrsasign",
							"masonry-layout",
							"swagger-ui-dist/swagger-ui-bundle",
							"swagger-ui-dist/swagger-ui-standalone-preset"
						],
						"inlineStyleLanguage": "scss",
						"assets": [
							"projects/apicat-app/src/favicon.ico",
							"projects/apicat-app/src/assets"
						],
						"styles": [
							"./node_modules/swagger-ui-dist/swagger-ui.css",
							"./node_modules/@fortawesome/fontawesome-free/css/all.min.css",
							"projects/apicat-app/src/styles.scss"
						],
						"stylePreprocessorOptions": {
							"includePaths": [
								"styles"
							]
						},
						"scripts": [
							"node_modules/jquery/dist/jquery.min.js",
							"node_modules/bootstrap/dist/js/bootstrap.bundle.min.js",
							"node_modules/file-saver/dist/FileSaver.min.js"
						]
					},
					"configurations": {
						"production": {
							"budgets": [
								{
									"type": "initial",
									"maximumWarning": "5mb",
									"maximumError": "5mb"
								},
								{
									"type": "anyComponentStyle",
									"maximumWarning": "6kb",
									"maximumError": "10kb"
								}
							],
							"fileReplacements": [
								{
									"replace": "projects/apicat-app/src/environments/environment.ts",
									"with": "projects/apicat-app/src/environments/environment.prod.ts"
								}
							],
							"outputHashing": "all"
						},
						"development": {
							"optimization": false,
							"extractLicenses": false,
							"sourceMap": true
						},
						"development-baseref": {
							"optimization": false,
							"extractLicenses": false,
							"sourceMap": true,
							"baseHref": "/apicat-app/"
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "@angular/build:dev-server",
					"configurations": {
						"production": {
							"buildTarget": "apicat-app:build:production"
						},
						"development": {
							"buildTarget": "apicat-app:build:development"
						},
						"development-baseref": {
							"buildTarget": "apicat-app:build:development-baseref",
							"servePath": "/apicat-app/",
							"proxyConfig": "proxy.config.json"
						}
					},
					"defaultConfiguration": "development",
					"options": {
						"port": 6200
					}
				},
				"extract-i18n": {
					"builder": "@angular/build:extract-i18n",
					"options": {
						"buildTarget": "apicat-app:build"
					}
				},
				"test": {
					"builder": "@angular/build:unit-test",
					"options": {
						"buildTarget": "apicat-app:build:development",
						"tsConfig": "projects/apicat-app/tsconfig.spec.json",
						"runnerConfig": true,
						"coverageExclude": [
							"**/*.html"
						]
					}
				}
			}
		}
	},
	"schematics": {
		"@schematics/angular:component": {
			"type": "component"
		},
		"@schematics/angular:directive": {
			"type": "directive"
		},
		"@schematics/angular:service": {
			"type": "service"
		},
		"@schematics/angular:guard": {
			"typeSeparator": "."
		},
		"@schematics/angular:interceptor": {
			"typeSeparator": "."
		},
		"@schematics/angular:module": {
			"typeSeparator": "."
		},
		"@schematics/angular:pipe": {
			"typeSeparator": "."
		},
		"@schematics/angular:resolver": {
			"typeSeparator": "."
		}
	}
}
